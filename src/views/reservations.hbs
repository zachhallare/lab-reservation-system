<title>My Reservations | Labubu</title>
<meta name="description" content="Labubu - DLSU Computer Lab Reservation System">

<!-- Navbar -->
<nav class="navbar" id="navbar">
    <div class="nav-container">
        <a href="/dashboard" class="nav-logo">
            <span class="logo-icon"><img src="/images/DLSU_Logo.png" alt="DLSU Logo"
                    style="height:1.5em;vertical-align:middle;"></span>
            <span class="logo-text">Labubu</span>
        </a>
        <div class="nav-links" id="navLinks">
            <a href="/dashboard" class="nav-link" data-page="dashboard">Dashboard</a>
            <a href="/reservations" class="nav-link active" data-page="reservations">My Reservations</a>
            <a href="/technician" class="nav-link" data-page="technician" id="navTechnician" style="display: none;">Technician</a>
        </div>
        <div class="nav-user" id="navUser">
            <div class="user-dropdown">
                <button class="user-btn" onclick="toggleUserMenu()">
                    <div class="user-avatar" id="navAvatar">U</div>
                    <span class="user-name" id="navUserName">User</span>
                    <span class="dropdown-arrow">▼</span>
                </button>
                <div class="dropdown-menu" id="dropdownMenu">
                    <a href="/profile"><img src="/images/DLSU_Logo.png" alt="DLSU Logo"
                            style="height:1em;vertical-align:middle;"> Profile</a>
                    <a href="#" onclick="logout()"><img src="/images/DLSU_Logo.png" alt="DLSU Logo"
                            style="height:1em;vertical-align:middle;"> Logout</a>
                </div>
            </div>
        </div>
        <button class="nav-toggle" onclick="toggleMobileNav()"><img src="/images/DLSU_Logo.png" alt="Menu"
                style="height:1em;vertical-align:middle;"></button>
    </div>
</nav>

<!-- Reservations Page -->
<section class="page reservations-page" id="reservationsPage" style="display: block;">
    <div class="page-container">
        <div class="page-header">
            <h1>My Reservations</h1>
        </div>
        <div class="reservations-tabs">
            <button class="tab-btn active" onclick="switchReservationTab('upcoming')">Upcoming</button>
            <button class="tab-btn" onclick="switchReservationTab('past')">Past</button>
        </div>
        <div class="reservations-list" id="reservationsList"></div>
    </div>
</section>

<!-- Footer -->
<footer class="footer" id="footer">
    <div class="footer-content">
        <div class="footer-brand"><span class="logo-icon"><img src="/images/DLSU_Logo.png" alt="DLSU Logo"
                    style="height:1.5em;vertical-align:middle;"></span><span>Labubu</span></div>
        <p class="footer-credits">Made By: Ralph Del Rosario | Zach Hallare | Keifer Sy | Farrell Tadina </p>
        <p class="footer-copyright">© 2026 De La Salle University</p>
    </div>
</footer>

<!-- Toast Container -->
<div class="toast-container" id="toastContainer"></div>

<!-- Modal -->
<div class="modal-overlay" id="modalOverlay" style="display: none;">
    <div class="modal glass-card">
        <h2 id="modalTitle">Confirm</h2>
        <p id="modalMessage">Are you sure?</p>
        <div class="modal-actions">
            <button class="btn btn-primary" id="modalConfirm">Confirm</button>
            <button class="btn btn-secondary" onclick="closeModal()">Cancel</button>
        </div>
    </div>
</div>

<!-- Edit Reservation Modal -->
<div class="modal-overlay" id="editReservationModal" style="display: none;">
    <div class="modal glass-card" style="max-width: 500px;">
        <h2>✏️ Edit Reservation</h2>
        <p id="editResLabName" style="font-weight:600; color: var(--primary);"></p>
        <div class="form-group" style="margin-top: 1rem;">
            <label>Date</label>
            <input type="date" id="editResDate">
        </div>
        <div class="form-group">
            <label>Seat Number</label>
            <input type="number" id="editResSeat" min="1">
        </div>
        <div class="form-group">
            <label>Time Slots</label>
            <div id="editResTimeSlots" class="edit-time-grid"></div>
        </div>
        <div class="modal-actions">
            <button class="btn btn-primary" onclick="saveEditReservation()">Save Changes</button>
            <button class="btn btn-secondary" onclick="closeEditModal()">Cancel</button>
        </div>
    </div>
</div>

<!-- JavaScript Modules -->
<script src="/js/data.js"></script>
<script src="/js/state.js"></script>
<script src="/js/utils.js"></script>
<script src="/js/reservations.js"></script>
<script>
    // Check auth and initialize
    document.addEventListener('DOMContentLoaded', async () => {
        // Check if logged in via server session
        try {
            const res = await fetch('/api/session');
            const data = await res.json();
            if (!data.loggedIn) {
                window.location.href = '/login';
                return;
            }
            state.currentUser = data.user;
        } catch (e) {
            window.location.href = '/login';
            return;
        }

        await initializeData();

        // Update UI
        updateNavUser();
        renderReservations('upcoming');
        setupEventListeners();
    });

    function updateNavUser() {
        if (state.currentUser) {
            const avatar = document.getElementById('navAvatar');
            const name = document.getElementById('navUserName');
            if (state.currentUser.profilePicture) {
                avatar.innerHTML = `<img src="${state.currentUser.profilePicture}" alt="${state.currentUser.firstName}" style="width:100%;height:100%;border-radius:50%;object-fit:cover;">`;
            } else {
                avatar.innerHTML = '';
                avatar.textContent = state.currentUser.firstName[0].toUpperCase();
            }
            name.textContent = state.currentUser.firstName;

            const techLink = document.getElementById('navTechnician');
            if (techLink) {
                techLink.style.display = state.currentUser.role === 'technician' ? 'block' : 'none';
            }
        }
    }

    function setupEventListeners() {
        document.addEventListener('click', (e) => {
            const dropdown = document.getElementById('dropdownMenu');
            const userBtn = document.querySelector('.user-btn');
            if (dropdown && !dropdown.contains(e.target) && !userBtn?.contains(e.target)) {
                dropdown.classList.remove('show');
            }
        });
    }

    async function logout() {
        try { await fetch('/api/logout', { method: 'POST' }); } catch(e) {}
        state.currentUser = null;
        window.location.href = '/login';
    }

    function toggleMobileNav() {
        document.getElementById('navLinks').classList.toggle('show');
    }

    function toggleUserMenu() {
        document.getElementById('dropdownMenu').classList.toggle('show');
    }

    // Override navigateTo for multi-page
    function navigateTo(page) {
        if (page === 'dashboard') {
            window.location.href = '/dashboard';
        }
    }
</script>
