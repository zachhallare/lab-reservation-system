<title>Profile | Labubu</title>
<meta name="description" content="Labubu - DLSU Computer Lab Reservation System">

<!-- Navbar -->
<nav class="navbar" id="navbar">
    <div class="nav-container">
        <a href="/dashboard" class="nav-logo">
            <span class="logo-icon"><img src="/images/DLSU_Logo.png" alt="DLSU Logo"
                    style="height:1.5em;vertical-align:middle;"></span>
            <span class="logo-text">Labubu</span>
        </a>
        <div class="nav-links" id="navLinks">
            <a href="/dashboard" class="nav-link" data-page="dashboard">Dashboard</a>
            <a href="/reservations" class="nav-link" data-page="reservations">My Reservations</a>
            <a href="/technician" class="nav-link" data-page="technician" id="navTechnician" style="display: none;">Technician</a>
        </div>
        <div class="nav-user" id="navUser">
            <div class="user-dropdown">
                <button class="user-btn" onclick="toggleUserMenu()">
                    <div class="user-avatar" id="navAvatar">U</div>
                    <span class="user-name" id="navUserName">User</span>
                    <span class="dropdown-arrow">▼</span>
                </button>
                <div class="dropdown-menu" id="dropdownMenu">
                    <a href="/profile"><img src="/images/DLSU_Logo.png" alt="DLSU Logo"
                            style="height:1em;vertical-align:middle;"> Profile</a>
                    <a href="#" onclick="logout()"><img src="/images/DLSU_Logo.png" alt="DLSU Logo"
                            style="height:1em;vertical-align:middle;"> Logout</a>
                </div>
            </div>
        </div>
        <button class="nav-toggle" onclick="toggleMobileNav()"><img src="/images/DLSU_Logo.png" alt="Menu"
                style="height:1em;vertical-align:middle;"></button>
    </div>
</nav>

<!-- Profile Page -->
<section class="page profile-page" id="profilePage" style="display: block;">
    <div class="page-container">
        <div class="profile-header">
            <div class="profile-cover"></div>
            <div class="profile-info">
                <div class="profile-avatar" id="profileAvatar">U</div>
                <div class="profile-details">
                    <h1 id="profileName">User</h1>
                    <span class="profile-role" id="profileRole">Student</span>
                    <p id="profileEmail">user@dlsu.edu.ph</p>
                </div>
                <button class="btn btn-secondary" onclick="toggleEditProfile()"><img src="/images/DLSU_Logo.png"
                        alt="DLSU Logo" style="height:1em;vertical-align:middle;"> Edit</button>
            </div>
        </div>
        <div class="profile-edit glass-card" id="profileEditSection" style="display: none;">
            <h3>Edit Profile</h3>
            <form id="editProfileForm" onsubmit="saveProfile(event)">
                <div class="form-row">
                    <div class="form-group">
                        <label>First Name</label>
                        <input type="text" id="editFirstName" required>
                    </div>
                    <div class="form-group">
                        <label>Last Name</label>
                        <input type="text" id="editLastName" required>
                    </div>
                </div>
                <div class="form-group">
                    <label>Profile Picture</label>
                    <input type="file" id="editProfilePicture" accept="image/*"
                        onchange="previewProfilePicture(event)">
                    <img id="profilePicturePreview" src="" alt="Preview"
                        style="display:none; width:80px; height:80px; border-radius:50%; object-fit:cover; margin-top:8px;">
                </div>
                <div class="form-group">
                    <label>Description</label>
                    <textarea id="editDescription" rows="3"></textarea>
                </div>
                <div class="action-buttons">
                    <button type="submit" class="btn btn-primary">Save</button>
                    <button type="button" class="btn btn-secondary" onclick="toggleEditProfile()">Cancel</button>
                </div>
            </form>
        </div>
        <div class="profile-description glass-card">
            <h3>About</h3>
            <p id="profileDescription">No description.</p>
        </div>
        <div class="profile-reservations glass-card">
            <h3>Current Reservations</h3>
            <div id="profileReservationsList"></div>
        </div>
        <div class="danger-zone glass-card">
            <h3><img src="/images/DLSU_Logo.png" alt="DLSU Logo" style="height:1em;vertical-align:middle;"> Danger
                Zone</h3>
            <p>Deleting removes all data.</p>
            <button class="btn btn-danger" onclick="deleteAccount()">Delete Account</button>
        </div>
    </div>
</section>

<!-- Footer -->
<footer class="footer" id="footer">
    <div class="footer-content">
        <div class="footer-brand"><span class="logo-icon"><img src="/images/DLSU_Logo.png" alt="DLSU Logo"
                    style="height:1.5em;vertical-align:middle;"></span><span>Labubu</span></div>
        <p class="footer-credits">Group # | Members: Del Rosario, Ralph Andrei | Hallare, Zach Benedict | Sy, Keifer
            Kaiser | Tadina, Farrell</p>
        <p class="footer-copyright">© 2026 De La Salle University</p>
    </div>
</footer>

<!-- Toast Container -->
<div class="toast-container" id="toastContainer"></div>

<!-- Modal -->
<div class="modal-overlay" id="modalOverlay" style="display: none;">
    <div class="modal glass-card">
        <h2 id="modalTitle">Confirm</h2>
        <p id="modalMessage">Are you sure?</p>
        <div class="modal-actions">
            <button class="btn btn-primary" id="modalConfirm">Confirm</button>
            <button class="btn btn-secondary" onclick="closeModal()">Cancel</button>
        </div>
    </div>
</div>

<!-- JavaScript Modules -->
<script src="/js/data.js"></script>
<script src="/js/state.js"></script>
<script src="/js/utils.js"></script>
<script src="/js/profile.js"></script>
<script>
    // Check auth and initialize
    document.addEventListener('DOMContentLoaded', async () => {
        // Check if logged in via server session
        try {
            const res = await fetch('/api/session');
            const data = await res.json();
            if (!data.loggedIn) {
                window.location.href = '/login';
                return;
            }
            state.currentUser = data.user;
        } catch (e) {
            window.location.href = '/login';
            return;
        }

        await initializeData();

        // Update UI
        updateNavUser();
        renderProfile();
        setupEventListeners();
    });

    function updateNavUser() {
        if (state.currentUser) {
            const avatar = document.getElementById('navAvatar');
            const name = document.getElementById('navUserName');
            if (state.currentUser.profilePicture) {
                avatar.innerHTML = `<img src="${state.currentUser.profilePicture}" alt="${state.currentUser.firstName}" style="width:100%;height:100%;border-radius:50%;object-fit:cover;">`;
            } else {
                avatar.innerHTML = '';
                avatar.textContent = state.currentUser.firstName[0].toUpperCase();
            }
            name.textContent = state.currentUser.firstName;

            const techLink = document.getElementById('navTechnician');
            if (techLink) {
                techLink.style.display = state.currentUser.role === 'technician' ? 'block' : 'none';
            }
        }
    }

    function setupEventListeners() {
        document.addEventListener('click', (e) => {
            const dropdown = document.getElementById('dropdownMenu');
            const userBtn = document.querySelector('.user-btn');
            if (dropdown && !dropdown.contains(e.target) && !userBtn?.contains(e.target)) {
                dropdown.classList.remove('show');
            }
        });
    }

    async function logout() {
        try { await fetch('/api/logout', { method: 'POST' }); } catch(e) {}
        state.currentUser = null;
        window.location.href = '/login';
    }

    function toggleMobileNav() {
        document.getElementById('navLinks').classList.toggle('show');
    }

    function toggleUserMenu() {
        document.getElementById('dropdownMenu').classList.toggle('show');
    }

    // Override deleteAccount to redirect
    const originalDeleteAccount = deleteAccount;
    deleteAccount = function () {
        showModal('Delete Account', 'This will permanently delete your account and all reservations. This action cannot be undone.', async () => {
            try {
                await fetch(`/api/users/${state.currentUser.id}`, { method: 'DELETE' });
                showToast('Account deleted successfully', 'info');
                setTimeout(() => {
                    logout();
                }, 1500);
            } catch (err) {
                showToast('Error deleting account', 'error');
            }
        });
    };
</script>
